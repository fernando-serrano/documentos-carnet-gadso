CARNET_OBSERVACION_POST_TRANSMITIR=Transmitido sin observaciones

# Mantenimiento local (servidor)
# Limpia data/cache/upload_tmp/<dni> al completar transmisión exitosa
CARNET_CACHE_CLEAN_ON_SUCCESS=1
# Cuando CARNET_LOG_SINGLE_FILE=0, conserva solo N logs por patrón de corrida
CARNET_LOG_ROTATING_KEEP_FILES=120
