# Rutas / ejecución
EXCEL_PATH=data/programaciones-armas.xlsx
# CARNET_RUN_MODE=scheduled|manual|test
RUN_MODE=scheduled
SCHEDULED_MULTIWORKER=1
# Número de workers para modo scheduled. Si SCHEDULED_MULTIWORKER=0, se ignora esta variable y se ejecuta con un solo worker.
SCHEDULED_WORKERS=4
# Número de filas a procesar por worker en modo scheduled. Si SCHEDULED_MULTIWORKER=0, se ignora esta variable y se procesan todas las filas.
CARNET_WORKER_SCAN_ROWS=200
CARNET_WORKER_MAX_ROWS=0
# Tiempo máximo para confirmar UI de CREAR SOLICITUD antes de considerar fallback/reintento.
CARNET_CREAR_SOLICITUD_VALIDATION_TIMEOUT_MS=9000
# Robustez de lectura CSV Google Sheets ante cortes intermitentes.
CARNET_GSHEET_READ_RETRIES=6
CARNET_GSHEET_TIMEOUT_SEC=35
CARNET_GSHEET_RETRY_BASE_MS=800
# Robustez OCR captcha
CARNET_OCR_MAX_INTENTOS=6
HOLD_BROWSER_OPEN=0
LOG_DIR=logs
SCREENSHOT_DIR=screenshots
VALIDAR_FECHA_PROGRAMACION_HOY=1

# OCR (EasyOCR)
EASYOCR_LANGS=en
EASYOCR_ALLOWLIST=ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789
EASYOCR_USE_GPU=0

# Google Sheets (fuente remota)
CARNET_GSHEET_URL=https://docs.google.com/spreadsheets/d/1I5CmLAxZxA5gIlHz_m5kDPTaHIs1yOEWvy7tN4Ia2hs/edit?pli=1&gid=999619533#gid=999619533
