# ============================================================
# GALENIUS (plantilla limpia)
# Copia este archivo a .env o integra las variables necesarias.
# ============================================================

# URL de acceso login Galenius
GALENIUS_URL_LOGIN=https://TU_DOMINIO_GALENIUS/login

# Credenciales (rellenar manualmente)
GALENIUS_USERNAME=
GALENIUS_PASSWORD=
# Ejecucion navegador
GALENIUS_HEADLESS=0
GALENIUS_TIMEOUT_MS=30000

# Criterios de validacion de login exitoso
# Separados por coma
GALENIUS_LOGIN_SUCCESS_SELECTORS=#dashboard,.dashboard,#menu-principal,nav .logout,a[href*='logout']
GALENIUS_LOGIN_SUCCESS_URL_CONTAINS=/dashboard,/inicio,/home

# Descarga y salida documental (etapa siguiente)
GALENIUS_OUTPUT_DIR=data/galenius
GALENIUS_MAX_PDF_KB=150

# Logging estructurado por corrida
GALENIUS_LOG_DIR=logs/galenius

# Modo previsto para lote (etapa siguiente)
GALENIUS_BATCH_SIZE=50
GALENIUS_OVERWRITE_EXISTING=0
